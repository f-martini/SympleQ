{
  "editor.renderWhitespace": "all",
  "editor.rulers": [
    120
  ],
  "editor.formatOnSave": true,
  "files.exclude": {
    "**/_autosummary": true
  },
  "search.exclude": {
    "**/_autosummary": true
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.autopep8"
  },
  "[cuda-cpp]": {
    "editor.defaultFormatter": "ms-vscode.cpptools"
  },
  "flake8.severity": {
    "C": "Warning",
    "E": "Warning",
    "F": "Warning",
    "R": "Hint",
    "W": "Warning",
    "I": "Information"
  },
  "autopep8.args": [
    "--ignore=E402,I100,I201,W504",
    "--select=W291,E101,E111,E114,E117,E121,E122,E123,E124,E126,E127,E128,E201,E202,E303,E501",
    "--max-line-length=120"
  ],
  "flake8.args": [
    "--config=${workspaceFolder}/scripts/configs/setup.cfg"
  ],
  "restructuredtext.linter.disabledLinters": [
    "doc8",
    "rstcheck"
  ],
  "cSpell.import": [
    "${workspaceFolder}/scripts/configs/cspell.json"
  ],
  "esbonio.server.pythonPath": "${workspaceFolder}/docs/doc_venv/Scripts/python",
  "esbonio.sphinx.confDir": "${workspaceFolder}/docs",
  "esbonio.sphinx.buildDir": "${workspaceFolder}/docs/_build",
  "python.analysis.typeCheckingMode": "basic",
  "python.testing.pytestArgs": ["tests"],
  "python.testing.unittestEnabled": false,
  "python.testing.pytestEnabled": true,
  "jupyter.notebookFileRoot": "${workspaceFolder}",
  "task.autoDetect": "off",
  "C_Cpp_Runner.cCompilerPath": "gcc",
  "C_Cpp_Runner.cppCompilerPath": "g++",
  "C_Cpp_Runner.debuggerPath": "gdb",
  "C_Cpp_Runner.cStandard": "",
  "C_Cpp_Runner.cppStandard": "",
  "C_Cpp_Runner.msvcBatchPath": "C:/Program Files/Microsoft Visual Studio/2022/Community/VC/Auxiliary/Build/vcvarsall.bat",
  "C_Cpp_Runner.useMsvc": false,
  "C_Cpp_Runner.warnings": [
    "-Wall",
    "-Wextra",
    "-Wpedantic",
    "-Wshadow",
    "-Wformat=2",
    "-Wcast-align",
    "-Wconversion",
    "-Wsign-conversion",
    "-Wnull-dereference"
  ],
  "C_Cpp_Runner.msvcWarnings": [
    "/W4",
    "/permissive-",
    "/w14242",
    "/w14287",
    "/w14296",
    "/w14311",
    "/w14826",
    "/w44062",
    "/w44242",
    "/w14905",
    "/w14906",
    "/w14263",
    "/w44265",
    "/w14928"
  ],
  "C_Cpp_Runner.enableWarnings": true,
  "C_Cpp_Runner.warningsAsError": false,
  "C_Cpp_Runner.compilerArgs": [],
  "C_Cpp_Runner.linkerArgs": [],
  "C_Cpp_Runner.includePaths": [],
  "C_Cpp_Runner.includeSearch": [
    "*",
    "**/*"
  ],
  "C_Cpp_Runner.excludeSearch": [
    "**/build",
    "**/build/**",
    "**/.*",
    "**/.*/**",
    "**/.vscode",
    "**/.vscode/**"
  ],
  "C_Cpp_Runner.useAddressSanitizer": false,
  "C_Cpp_Runner.useUndefinedSanitizer": false,
  "C_Cpp_Runner.useLeakSanitizer": false,
  "C_Cpp_Runner.showCompilationTime": false,
  "C_Cpp_Runner.useLinkTimeOptimization": false,
  "C_Cpp_Runner.msvcSecureNoWarnings": false,
  "C_Cpp.clang_format_sortIncludes": false,
  "C_Cpp.clang_format_fallbackStyle": "{ BasedOnStyle: Google, IndentWidth: 4,  ColumnLimit: 120, NamespaceIndentation: None, BinPackParameters: false, AlignAfterOpenBracket: Align, AccessModifierOffset: -4, AllowAllArgumentsOnNextLine: false}",
  "files.associations": {
        "map": "cpp",
        "complex": "cpp",
        "vector": "cpp"
  }
}